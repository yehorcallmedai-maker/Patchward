# RepoMend — environment variables
# Copy to .env and fill in your values. Never commit .env.
#
# Langfuse tracing (cloud free tier — https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here

# Anthropic API key (required for agent runs)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# GitHub PAT — required for Phase 5 PR push (AC-P5-02)
# Fine-grained PAT: Contents read+write on repomend-fixture
GITHUB_TOKEN=github_pat_your-token-here
